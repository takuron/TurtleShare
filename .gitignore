# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can generally be ignored
*.pdb

# SQLite databases
*.db
*.db-shm
*.db-wal

# Local configuration & Data
# Ignore the data directory where files and the database are stored
data/
# You might want to ignore the real config and track an example
# config.toml
# .env

# JetBrains IDEs (IntelliJ, RustRover, CLion, etc.)
.idea/
*.iml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

